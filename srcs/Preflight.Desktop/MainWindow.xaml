<Window
    x:Class="Preflight.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="preflight.xml"
    Width="1080"
    Height="900"
    MinWidth="800"
    MinHeight="600"
    Background="{StaticResource PfSurfaceDeepBrush}"
    Foreground="{StaticResource PfTextBrush}"
    Icon="favicon.ico"
    Opacity="0"
    ResizeMode="CanResize"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    AllowsTransparency="True">

    <!--
        WindowChrome enables Win11 aero-snap, drop shadow, and edge resize while
        letting us paint the title bar ourselves. CaptionHeight is the draggable
        strip; ResizeBorderThickness is the invisible band along the edges that
        triggers the resize cursor. UseAeroCaptionButtons=False is mandatory -
        without it Windows would draw its own min/max/close on top of ours.
    -->
    <WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="36"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border
        x:Name="RootBorder"
        Background="{StaticResource PfSurfaceDeepBrush}"
        BorderBrush="{StaticResource PfBorderBrush}"
        BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  ───── Custom title bar ─────  -->
            <Border
                Grid.Row="0"
                Background="{StaticResource PfSurfaceBrush}"
                BorderBrush="{StaticResource PfBorderBrush}"
                BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Brand mark: airplane in brand gradient + product name.  -->
                    <StackPanel
                        Grid.Column="0"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Viewbox Width="16" Height="16">
                            <Path Data="{StaticResource PfPlaneGeometry}"
                                Fill="{StaticResource PfBrandGradient}" />
                        </Viewbox>
                        <TextBlock
                            Margin="10,0,0,1"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="Medium"
                            Foreground="{StaticResource PfTextBrush}"
                            Text="preflight.xml" />
                    </StackPanel>

                    <!--
                        Caption buttons. IsHitTestVisibleInChrome opts each one out
                        of the WindowChrome drag region, so a click on minimize
                        actually minimizes instead of starting a window-drag.
                    -->
                    <StackPanel
                        Grid.Column="2"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Orientation="Horizontal">
                        <Button
                            x:Name="MinimizeButton"
                            Click="OnMinimizeClick"
                            Style="{StaticResource PfCaptionButtonStyle}"
                            ToolTip="Minimize">
                            <Path
                                Data="M0,5 H10"
                                SnapsToDevicePixels="True"
                                Stroke="{StaticResource PfTextBrush}"
                                StrokeThickness="1" />
                        </Button>

                        <Button
                            x:Name="MaxRestoreButton"
                            Click="OnMaxRestoreClick"
                            Style="{StaticResource PfCaptionButtonStyle}"
                            ToolTip="Maximize">
                            <Path
                                x:Name="MaxRestorePath"
                                Data="M0,0 H10 V10 H0 Z"
                                Fill="Transparent"
                                SnapsToDevicePixels="True"
                                Stroke="{StaticResource PfTextBrush}"
                                StrokeThickness="1" />
                        </Button>

                        <Button
                            x:Name="CloseButton"
                            Click="OnCloseClick"
                            Style="{StaticResource PfCaptionCloseButtonStyle}"
                            ToolTip="Close">
                            <Path
                                Data="M0,0 L10,10 M10,0 L0,10"
                                SnapsToDevicePixels="True"
                                Stroke="{StaticResource PfTextBrush}"
                                StrokeThickness="1" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--
                ───── WebView host ─────
                Visible from the start. The MainWindow itself is shown with
                Opacity=0 by App.OnStartup until the page renders, which keeps
                WebView2 in its "visible" state (HWND on-screen, normal Win32
                position) so it actually paints during boot. Once the page
                signals ready, App fades the window in and dismisses the
                splash - see App.OnStartup + MainWindow.FirstPageRendered.
            -->
            <Grid Grid.Row="1">
                <wv2:WebView2
                    x:Name="WebView"
                    DefaultBackgroundColor="#14152A" />

                <!--
                    Update-ready banner. Appears above the WebView when the
                    background updater finishes downloading a new release.
                    Pinned to the bottom so it doesn't cover the page header
                    and out-of-flow so toggling it doesn't reflow the WebView
                    underneath.
                -->
                <Border x:Name="UpdateBanner"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        Margin="14,0,14,14"
                        Padding="14,10"
                        Background="{StaticResource PfSurfaceBrush}"
                        BorderBrush="{StaticResource PfBorderStrongBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000"
                                          Direction="270"
                                          ShadowDepth="2"
                                          Opacity="0.45"
                                          BlurRadius="18" />
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Viewbox Grid.Column="0" Width="20" Height="20" Margin="0,0,12,0">
                            <Path Data="{StaticResource PfPlaneGeometry}"
                                  Fill="{StaticResource PfBrandGradient}" />
                        </Viewbox>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="UpdateBannerTitle"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PfTextBrush}" />
                            <TextBlock x:Name="UpdateBannerSubtitle"
                                       FontFamily="Segoe UI Variable, Segoe UI"
                                       FontSize="11"
                                       Foreground="{StaticResource PfTextSubtleBrush}" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                x:Name="UpdateDismissButton"
                                Click="OnUpdateDismissClick"
                                Margin="8,0,6,0"
                                Padding="10,4"
                                Background="Transparent"
                                BorderBrush="{StaticResource PfBorderBrush}"
                                BorderThickness="1"
                                Foreground="{StaticResource PfTextMutedBrush}"
                                Cursor="Hand">
                            <TextBlock x:Name="UpdateDismissText" FontSize="12" />
                        </Button>
                        <Button Grid.Column="3"
                                x:Name="UpdateRestartButton"
                                Click="OnUpdateRestartClick"
                                Padding="14,6"
                                Background="{StaticResource PfBrandGradient}"
                                BorderThickness="0"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Cursor="Hand">
                            <TextBlock x:Name="UpdateRestartText" FontSize="12" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
