<Window
    x:Class="Preflight.Desktop.UpdateBannerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowActivated="False"
    ShowInTaskbar="False"
    SizeToContent="WidthAndHeight"
    WindowStyle="None">

    <!--
        Transparent overlay window used to show the update-ready banner above
        WebView2. Because WebView2 is a Win32 HWND it ignores WPF Z-order, so
        the only reliable way to float WPF content on top of it is to use a
        separate top-level window. This window is kept in sync with the main
        window's position and size via MainWindow.
    -->
    <Border
        x:Name="BannerRoot"
        Margin="14"
        Padding="14,10"
        Background="{StaticResource PfSurfaceBrush}"
        BorderBrush="{StaticResource PfBorderStrongBrush}"
        BorderThickness="1"
        CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="18"
                Color="#000000"
                Direction="270"
                Opacity="0.45"
                ShadowDepth="2" />
        </Border.Effect>
        <Grid MinWidth="360">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock
                    x:Name="TitleText"
                    FontFamily="Segoe UI Variable, Segoe UI"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource PfTextBrush}" />
                <TextBlock
                    x:Name="SubtitleText"
                    FontFamily="Segoe UI Variable, Segoe UI"
                    FontSize="11"
                    Foreground="{StaticResource PfTextSubtleBrush}" />
            </StackPanel>
            <Button
                x:Name="DismissButton"
                Grid.Column="1"
                Margin="8,0,6,0"
                Padding="10,4"
                Background="Transparent"
                BorderBrush="{StaticResource PfBorderBrush}"
                BorderThickness="1"
                Click="OnDismissClick"
                Cursor="Hand"
                Foreground="{StaticResource PfTextMutedBrush}">
                <TextBlock x:Name="DismissText" FontSize="12" />
            </Button>
            <Button
                x:Name="RestartButton"
                Grid.Column="2"
                Padding="14,6"
                Background="{StaticResource PfBrandGradient}"
                BorderThickness="0"
                Click="OnRestartClick"
                Cursor="Hand"
                FontWeight="SemiBold"
                Foreground="White">
                <TextBlock x:Name="RestartText" FontSize="12" />
            </Button>
        </Grid>
    </Border>
</Window>
