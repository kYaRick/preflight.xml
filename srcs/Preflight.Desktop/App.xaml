<Application x:Class="Preflight.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    Theme tokens mirror Preflight.App's css/app.css dark palette so the WPF
    chrome (custom title bar, splash, frame) reads as one continuous surface
    with the WebView-hosted page. Keys mirror the css custom property names
    on the web side (pf-surface, pf-accent, ...) for easy cross-referencing.
  -->
    <Application.Resources>

        <!-- Brand palette (mirrors the pf- css tokens, dark variant) -->
        <Color x:Key="PfSurface">#FF1C1F36</Color>
        <Color x:Key="PfSurfaceDeep">#FF14152A</Color>
        <Color x:Key="PfSurface2">#FF242845</Color>
        <Color x:Key="PfBorder">#FF2C2F4A</Color>
        <Color x:Key="PfBorderStrong">#FF3D2A5A</Color>
        <Color x:Key="PfText">#FFEEF1F8</Color>
        <Color x:Key="PfTextMuted">#FFB4BAC8</Color>
        <Color x:Key="PfTextSubtle">#FF7C849A</Color>
        <Color x:Key="PfAccent">#FF8B5CF6</Color>
        <Color x:Key="PfAccentStrong">#FF6D28D9</Color>
        <Color x:Key="PfAccentLight">#FFA855F7</Color>
        <Color x:Key="PfDanger">#FFE81123</Color>

        <SolidColorBrush x:Key="PfSurfaceBrush" Color="{StaticResource PfSurface}" />
        <SolidColorBrush x:Key="PfSurfaceDeepBrush" Color="{StaticResource PfSurfaceDeep}" />
        <SolidColorBrush x:Key="PfBorderBrush" Color="{StaticResource PfBorder}" />
        <SolidColorBrush x:Key="PfBorderStrongBrush" Color="{StaticResource PfBorderStrong}" />
        <SolidColorBrush x:Key="PfTextBrush" Color="{StaticResource PfText}" />
        <SolidColorBrush x:Key="PfTextMutedBrush" Color="{StaticResource PfTextMuted}" />
        <SolidColorBrush x:Key="PfTextSubtleBrush" Color="{StaticResource PfTextSubtle}" />
        <SolidColorBrush x:Key="PfDangerBrush" Color="{StaticResource PfDanger}" />

        <LinearGradientBrush x:Key="PfBrandGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource PfAccentLight}" Offset="0" />
            <GradientStop Color="{StaticResource PfAccentStrong}" Offset="1" />
        </LinearGradientBrush>

        <!-- Inline airplane geometry, lifted from .github/assets/icon.svg
             (24x24 viewBox). Reused by the splash, title bar, and any
             future chrome that needs the brand mark in vector form. -->
        <Geometry x:Key="PfPlaneGeometry">
            M21,16 v-2 l-8,-5 V3.5 A1.5,1.5 0 0 0 11.5,2 A1.5,1.5 0 0 0 10,3.5 V9 l-8,5 v2 l8,-2.5 V19 l-2,1.5 V22 l3.5,-1 l3.5,1 v-1.5 L13,19 v-5.5 z
        </Geometry>

        <!-- Caption (window) buttons. Min/Max share the neutral hover; Close
             gets a red hover to match Win11/Edge title bar conventions. -->
        <Style x:Key="PfCaptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="{StaticResource PfTextBrush}" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#11FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PfCaptionCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="{StaticResource PfTextBrush}" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PfDangerBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C00F1F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
