<Window x:Class="Preflight.Desktop.SplashWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="preflight.xml"
    Width="540" Height="320"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>
        <Storyboard x:Key="ShimmerStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShimmerTransform"
                             Storyboard.TargetProperty="X"
                             From="-160" To="492"
                             Duration="0:0:1.6" />
        </Storyboard>

        <Storyboard x:Key="PlaneBobStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="PlaneTransform"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-6"
                             Duration="0:0:1.4">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource ShimmerStoryboard}" />
            <BeginStoryboard Storyboard="{StaticResource PlaneBobStoryboard}" />
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="14"
            Background="{StaticResource PfSurfaceBrush}"
            BorderBrush="{StaticResource PfBorderStrongBrush}"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              Direction="270"
                              ShadowDepth="2"
                              Opacity="0.45"
                              BlurRadius="22" />
        </Border.Effect>

        <Grid>
            <Ellipse Width="520" Height="520"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-220,-200,0"
                     IsHitTestVisible="False"
                     Opacity="0.55">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFA855F7" Offset="0" />
                        <GradientStop Color="#006D28D9" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="0,0,0,18">
                <Viewbox Width="84" Height="84">
                    <Path Data="{StaticResource PfPlaneGeometry}"
                          Fill="{StaticResource PfBrandGradient}"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <TranslateTransform x:Name="PlaneTransform" />
                        </Path.RenderTransform>
                    </Path>
                </Viewbox>
                <TextBlock Text="preflight.xml"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PfTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,0" />
                <TextBlock Text="Visual builder for Windows autounattend.xml"
                           FontFamily="Segoe UI Variable, Segoe UI"
                           FontSize="12"
                           Foreground="{StaticResource PfTextSubtleBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <StackPanel VerticalAlignment="Bottom" Margin="24,0,24,18">
                <Border Height="2"
                        CornerRadius="1"
                        Background="{StaticResource PfBorderBrush}"
                        ClipToBounds="True">
                    <Rectangle Width="160" HorizontalAlignment="Left">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#006D28D9" Offset="0" />
                                <GradientStop Color="#FFA855F7" Offset="0.5" />
                                <GradientStop Color="#006D28D9" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.RenderTransform>
                            <TranslateTransform x:Name="ShimmerTransform" X="-160" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Border>

                <Grid Margin="0,10,0,0">
                    <TextBlock x:Name="StatusText"
                               Text="Loading…"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="11"
                               Foreground="{StaticResource PfTextSubtleBrush}"
                               HorizontalAlignment="Left" />
                    <TextBlock x:Name="VersionText"
                               FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="11"
                               Foreground="{StaticResource PfTextSubtleBrush}"
                               HorizontalAlignment="Right" />
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
