@page "/"
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Nav
@inject ModeService Mode
@inject ImportModalService ImportModal

<PageTitle>preflight.xml</PageTitle>

<div class="landing">

    <div style="padding: 72px 16px 24px; text-align: center; max-width: 960px; margin: 0 auto;">
        <h1 class="pf-hero-title pf-hero-title--with-icon" style="font-size: clamp(2.25rem, 4.5vw, 3.5rem); font-weight: 700; margin: 0 0 0.75rem; font-family: var(--pf-font-sans);">
            <BrandIcon CssClass="pf-hero-icon" AriaLabel="preflight.xml" />
            <span class="pf-hero-title__text">preflight.xml</span>
        </h1>
        <p style="font-size: clamp(1rem, 1.4vw, 1.1875rem); color: var(--pf-text-muted); margin: 0 auto; max-width: 640px; line-height: 1.5;">
            @L["Landing.Tagline"]
        </p>
    </div>

    <FluentGrid Spacing="3" Justify="JustifyContent.Center" Style="padding: 16px; max-width: 1200px; margin: 0 auto;">
        <FluentGridItem xs="12" sm="12" md="4">
            <ModeCard Icon="✈️"
                      Title="@L["Landing.Wizard.Title"]"
                      Description="@L["Landing.Wizard.Description"]"
                      CtaLabel="@L["Landing.Wizard.Cta"]"
                      Href="wizard"
                      OnSelect="@(() => Mode.SwitchMode(AppMode.Wizard))" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="12" md="4">
            <ModeCard Icon="⚙️"
                      Title="@L["Landing.Advanced.Title"]"
                      Description="@L["Landing.Advanced.Description"]"
                      CtaLabel="@L["Landing.Advanced.Cta"]"
                      Href="advanced"
                      OnSelect="@(() => Mode.SwitchMode(AppMode.Advanced))" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="12" md="4">
            <ModeCard Icon="📖"
                      Title="@L["Landing.Docs.Title"]"
                      Description="@L["Landing.Docs.Description"]"
                      CtaLabel="@L["Landing.Docs.Cta"]"
                      Href="docs"
                      OnSelect="@(() => Mode.SwitchMode(AppMode.Docs))" />
        </FluentGridItem>
    </FluentGrid>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="10" HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 32px 16px; text-align: center;">
        <FluentLabel Typo="Typography.Body">@L["Landing.Import.Prompt"]</FluentLabel>
        <FluentButton Appearance="Appearance.Outline" OnClick="OpenImport">
            <text>📥 @L["Landing.Import.Button"]</text>
        </FluentButton>

        @if (_importMessage is not null)
        {
            <FluentMessageBar Intent="@_importIntent" AllowDismiss="true" OnDismiss="DismissImport" Style="max-width: 720px;">
                @_importMessage
            </FluentMessageBar>
        }
    </FluentStack>

</div>

@code {
    private string? _importMessage;
    private MessageIntent _importIntent = MessageIntent.Info;

    // The modal itself is rendered by MainLayout (so its overlay sits in
    // the layout-root stacking context and can blur the sticky header).
    // Here we only own the trigger and the result handling.
    private void OpenImport() => ImportModal.Open(HandleImported);

    private async Task HandleImported(ImportXmlModal.ImportPayload payload)
    {
        _importMessage = null;
        try
        {
            switch (payload.Result.Status)
            {
                case ImportStatus.Roundtrip:
                    Mode.ReplaceConfig(payload.Result.Config!);
                    _importIntent = MessageIntent.Success;
                    _importMessage = string.Format(L["Landing.Import.Success"].Value, payload.SourceName);
                    ImportModal.Close();
                    Nav.NavigateTo("advanced");
                    break;

                case ImportStatus.Partial:
                    Mode.ReplaceConfig(payload.Result.Config!);
                    _importIntent = MessageIntent.Warning;
                    _importMessage = string.Format(L["Landing.Import.Partial"].Value, payload.SourceName)
                        + " " + string.Join(" ", payload.Result.Messages);
                    ImportModal.Close();
                    Nav.NavigateTo("advanced");
                    break;

                case ImportStatus.Failed:
                    // Fallback path: if failure reaches page-level handling,
                    // close modal so the landing banner is actually visible.
                    _importIntent = MessageIntent.Error;
                    _importMessage = string.Format(L["Landing.Import.Failed"].Value, string.Join(" ", payload.Result.Messages));
                    ImportModal.Close();
                    break;
            }
        }
        catch (Exception ex)
        {
            _importIntent = MessageIntent.Error;
            _importMessage = string.Format(L["Landing.Import.Failed"].Value, ex.Message);
        }
        await InvokeAsync(StateHasChanged);
    }

    private void DismissImport() => _importMessage = null;
}
