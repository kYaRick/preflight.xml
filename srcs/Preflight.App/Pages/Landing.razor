@page "/"
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Nav
@inject ModeService Mode
@inject ImportModalService ImportModal

<PageTitle>preflight.xml</PageTitle>

<div class="landing">

    <div style="padding: 72px 16px 24px; text-align: center; max-width: 960px; margin: 0 auto;">
        <h1 class="pf-hero-title pf-hero-title--with-icon" style="font-size: clamp(2.25rem, 4.5vw, 3.5rem); font-weight: 700; margin: 0 0 0.75rem; font-family: var(--pf-font-sans);">
            <BrandIcon CssClass="pf-hero-icon" AriaLabel="preflight.xml" />
            <span class="pf-hero-title__text">preflight.xml</span>
        </h1>
        <p style="font-size: clamp(1rem, 1.4vw, 1.1875rem); color: var(--pf-text-muted); margin: 0 auto; max-width: 640px; line-height: 1.5;">
            @L["Landing.Tagline"]
        </p>
    </div>

    <FluentGrid Spacing="3" Justify="JustifyContent.Center" Style="padding: 16px; max-width: 1200px; margin: 0 auto;">
        <FluentGridItem xs="12" sm="12" md="4">
            <ModeCard Icon="✈️"
                      Title="@L["Landing.Wizard.Title"]"
                      Description="@L["Landing.Wizard.Description"]"
                      CtaLabel="@L["Landing.Wizard.Cta"]"
                      Href="wizard"
                      OnSelect="@(() => Mode.SwitchMode(AppMode.Wizard))" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="12" md="4">
            <ModeCard Icon="⚙️"
                      Title="@L["Landing.Advanced.Title"]"
                      Description="@L["Landing.Advanced.Description"]"
                      CtaLabel="@L["Landing.Advanced.Cta"]"
                      Href="advanced"
                      OnSelect="@(() => Mode.SwitchMode(AppMode.Advanced))" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="12" md="4">
            <ModeCard Icon="📖"
                      Title="@L["Landing.Docs.Title"]"
                      Description="@L["Landing.Docs.Description"]"
                      CtaLabel="@L["Landing.Docs.Cta"]"
                      Href="docs"
                      OnSelect="@(() => Mode.SwitchMode(AppMode.Docs))" />
        </FluentGridItem>
    </FluentGrid>

    @*
        Secondary actions paired as two cards under the primary trio: a "how to
        use" guide (navigates to /guide) and "already have a config" (opens the
        import modal). Same 1200px frame as the primary trio; two half-width cards
        (md=6) so the pair stretches edge-to-edge, level with the three above.
    *@
    <FluentGrid Spacing="3" Justify="JustifyContent.Center" Style="padding: 8px 16px 48px; max-width: 1200px; margin: 0 auto;">
        <FluentGridItem xs="12" sm="6" md="6">
            <a href="guide" class="pf-mode-card-anchor">
                <FluentCard Class="pf-card--interactive" Style="height: 100%;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8" Style="padding: 16px 18px; height: 100%;">
                        <div style="font-size: 30px; line-height: 1;">🚀</div>
                        <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@L["Landing.Guide.Title"]</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Style="flex: 1;">@L["Landing.Guide.Subtitle"]</FluentLabel>
                        <FluentButton Appearance="Appearance.Accent" Style="pointer-events: none;">@L["Landing.Guide.Cta"]</FluentButton>
                    </FluentStack>
                </FluentCard>
            </a>
        </FluentGridItem>
        <FluentGridItem xs="12" sm="6" md="6">
            <div class="pf-mode-card-anchor" role="button" tabindex="0" @onclick="OpenImport" @onkeydown="OnImportKey">
                <FluentCard Class="pf-card--interactive" Style="height: 100%;">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8" Style="padding: 16px 18px; height: 100%;">
                        <div style="font-size: 30px; line-height: 1;">📥</div>
                        <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@L["Landing.Import.Prompt"]</FluentLabel>
                        <FluentLabel Typo="Typography.Body" Style="flex: 1;">@L["Landing.Import.Description"]</FluentLabel>
                        <FluentButton Appearance="Appearance.Accent" Style="pointer-events: none;">📥 @L["Landing.Import.Button"]</FluentButton>
                    </FluentStack>
                </FluentCard>
            </div>
        </FluentGridItem>
    </FluentGrid>

    @if (_importMessage is not null)
    {
        <div style="max-width: 720px; margin: 0 auto; padding: 0 16px 48px; text-align: center;">
            <FluentMessageBar Intent="@_importIntent" AllowDismiss="true" OnDismiss="DismissImport">
                @_importMessage
            </FluentMessageBar>
        </div>
    }

</div>

@code {
    private string? _importMessage;
    private MessageIntent _importIntent = MessageIntent.Info;

    // The modal itself is rendered by MainLayout (so its overlay sits in the
    // layout-root stacking context and can blur the sticky header). Here we only
    // own the trigger and the result handling.
    private void OpenImport() => ImportModal.Open(HandleImported);

    // Keyboard activation for the div-based import card (Enter / Space) so the
    // tile is reachable without a mouse, like a real button.
    private void OnImportKey(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " " or "Spacebar") OpenImport();
    }

    private async Task HandleImported(ImportXmlModal.ImportPayload payload)
    {
        _importMessage = null;
        try
        {
            switch (payload.Result.Status)
            {
                case ImportStatus.Roundtrip:
                    Mode.ReplaceConfig(payload.Result.Config!);
                    _importIntent = MessageIntent.Success;
                    _importMessage = string.Format(L["Landing.Import.Success"].Value, payload.SourceName);
                    ImportModal.Close();
                    Nav.NavigateTo("advanced");
                    break;

                case ImportStatus.Partial:
                    Mode.ReplaceConfig(payload.Result.Config!);
                    _importIntent = MessageIntent.Warning;
                    _importMessage = string.Format(L["Landing.Import.Partial"].Value, payload.SourceName)
                        + " " + string.Join(" ", payload.Result.Messages);
                    ImportModal.Close();
                    Nav.NavigateTo("advanced");
                    break;

                case ImportStatus.Failed:
                    // Fallback path: if failure reaches page-level handling, close
                    // the modal so the landing banner is actually visible.
                    _importIntent = MessageIntent.Error;
                    _importMessage = string.Format(L["Landing.Import.Failed"].Value, string.Join(" ", payload.Result.Messages));
                    ImportModal.Close();
                    break;
            }
        }
        catch (Exception ex)
        {
            _importIntent = MessageIntent.Error;
            _importMessage = string.Format(L["Landing.Import.Failed"].Value, ex.Message);
        }
        await InvokeAsync(StateHasChanged);
    }

    private void DismissImport() => _importMessage = null;
}
