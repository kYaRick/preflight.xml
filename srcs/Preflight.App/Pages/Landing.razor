@page "/"
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Nav
@inject ModeService Mode

<PageTitle>preflight.xml</PageTitle>

<div class="landing">

    <div style="padding: 72px 16px 24px; text-align: center; max-width: 960px; margin: 0 auto;">
        <h1 class="pf-hero-title" style="font-size: clamp(2.25rem, 4.5vw, 3.5rem); font-weight: 700; margin: 0 0 0.75rem; font-family: var(--pf-font-sans);">
            ✈️ preflight.xml
        </h1>
        <p style="font-size: clamp(1rem, 1.4vw, 1.1875rem); color: var(--pf-text-muted); margin: 0 auto; max-width: 640px; line-height: 1.5;">
            @L["Landing.Tagline"]
        </p>
        <div style="margin-top: 1.5rem;">
            <FluentMessageBar Intent="MessageIntent.Warning" Title="Pre-alpha" AllowDismiss="false">
                @L["Landing.Status"]
            </FluentMessageBar>
        </div>
    </div>

    <FluentGrid Spacing="3" Justify="JustifyContent.Center" Style="padding: 16px; max-width: 1200px; margin: 0 auto;">
        <FluentGridItem xs="12" sm="12" md="4">
            <ModeCard Icon="✈️"
                      Title="@L["Landing.Wizard.Title"]"
                      Description="@L["Landing.Wizard.Description"]"
                      CtaLabel="@L["Landing.Wizard.Cta"]"
                      OnSelect="GoToWizard" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="12" md="4">
            <ModeCard Icon="⚙️"
                      Title="@L["Landing.Advanced.Title"]"
                      Description="@L["Landing.Advanced.Description"]"
                      CtaLabel="@L["Landing.Advanced.Cta"]"
                      OnSelect="GoToAdvanced" />
        </FluentGridItem>
        <FluentGridItem xs="12" sm="12" md="4">
            <ModeCard Icon="📖"
                      Title="@L["Landing.Docs.Title"]"
                      Description="@L["Landing.Docs.Description"]"
                      CtaLabel="@L["Landing.Docs.Cta"]"
                      OnSelect="GoToDocs" />
        </FluentGridItem>
    </FluentGrid>

    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" HorizontalAlignment="HorizontalAlignment.Center" Style="padding: 32px 16px;">
        <FluentLabel Typo="Typography.Body">@L["Landing.Import.Prompt"]</FluentLabel>
        <FluentButton Appearance="Appearance.Outline" OnClick="OnImportClicked">
            <span class="pf-btn-icon">@((MarkupString)ImportIconSvg)</span>
            @L["Landing.Import.Button"]
        </FluentButton>
    </FluentStack>

    @if (_showImportToast)
    {
        <FluentMessageBar Intent="MessageIntent.Info" AllowDismiss="true" OnDismiss="DismissImportToast" Style="max-width: 640px; margin: 0 auto;">
            @L["Landing.Import.ComingSoon"]
        </FluentMessageBar>
    }

</div>

@code {
    private bool _showImportToast;

    // Monochrome import icon - a document with a down-arrow entering it.
    // Replaces 📥 emoji that renders inconsistently across Windows / fonts.
    private const string ImportIconSvg =
        @"<svg width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.7' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
            <path d='M14 3v4a1 1 0 0 0 1 1h4' />
            <path d='M17 21H7a2 2 0 0 1 -2 -2V5a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z' />
            <path d='M12 11v6' />
            <path d='M9.5 14.5l2.5 2.5 2.5 -2.5' />
          </svg>";

    private void GoToWizard() => GoTo(AppMode.Wizard, "/wizard");
    private void GoToAdvanced() => GoTo(AppMode.Advanced, "/advanced");
    private void GoToDocs() => GoTo(AppMode.Docs, "/docs");

    private void GoTo(AppMode mode, string path)
    {
        Mode.SwitchMode(mode);
        Nav.NavigateTo(path);
    }

    private void OnImportClicked() => _showImportToast = true;
    private void DismissImportToast() => _showImportToast = false;
}
