@page "/wizard/review"
@using Preflight.App.Services
@inject IStringLocalizer<SharedResources> L
@inject ModeService Mode
@inject NavigationManager Nav
@inject UnattendXmlBuilder XmlBuilder
@inject IJSRuntime JS

<PageTitle>@L["Wizard.Review.Title"] · preflight.xml</PageTitle>

<FluentStack Orientation="Orientation.Vertical" HorizontalGap="24" Style="padding: 48px 16px 96px; max-width: 900px; margin: 0 auto;">

    <FluentLabel Typo="Typography.PageTitle">📋 @L["Wizard.Review.Title"]</FluentLabel>
    <FluentLabel Typo="Typography.Subject">@L["Wizard.Review.Subtitle"]</FluentLabel>

    <FluentCard Style="padding: 24px;">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            <ReviewRow Label="@L["Region.DisplayLanguage.Label"]" Value="@Mode.Config.Region.DisplayLanguage" />
            <ReviewRow Label="@L["Region.HomeLocation.Label"]" Value="@Mode.Config.Region.HomeLocation" />
            <ReviewRow Label="@L["Disk.Mode.Label"]" Value="@Mode.Config.Disk.Mode.ToString()" />
            <ReviewRow Label="@L["Disk.PartitionStyle.Label"]" Value="@Mode.Config.Disk.PartitionStyle.ToString()" />
            <ReviewRow Label="@L["Edition.Edition.Label"]" Value="@Mode.Config.Edition.Edition.ToString()" />
            <ReviewRow Label="@L["Users.Count.Label"]" Value="@Mode.Config.Users.Count.ToString()" />
            <ReviewRow Label="@L["Privacy.Express.Label"]" Value="@Mode.Config.Privacy.ExpressSettings.ToString()" />
            <ReviewRow Label="@L["Bloatware.RemoveCount.Label"]" Value="@Mode.Config.Bloatware.AppsToRemove.Count.ToString()" />
        </FluentStack>
    </FluentCard>

    @if (_lastError is not null)
    {
        <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="true">
            @_lastError
        </FluentMessageBar>
    }

    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true" Style="row-gap: 8px;">
        <FluentAnchor Href="wizard" Appearance="Appearance.Outline">← @L["Common.Back"]</FluentAnchor>
        <FluentAnchor Href="advanced" Appearance="Appearance.Outline">⚙️ @L["Wizard.Review.Tweak"]</FluentAnchor>
        <FluentSpacer />
        <FluentButton Appearance="Appearance.Accent" OnClick="DownloadXml" Disabled="@_downloading">
            @if (_downloading)
            {
                <text>⏳ @L["Wizard.Review.Preparing"]</text>
            }
            else
            {
                <text>⬇️ @L["Wizard.Review.Download"]</text>
            }
        </FluentButton>
    </FluentStack>

</FluentStack>

@code {
    private bool _downloading;
    private string? _lastError;

    private async Task DownloadXml()
    {
        _downloading = true;
        _lastError = null;
        StateHasChanged();
        try
        {
            // Build autounattend.xml from the currently-applied preset/config and hand
            // it to the browser as a download. Any generator exception surfaces in-line
            // so the user knows what to go fix in /advanced.
            var xml = XmlBuilder.Build(Mode.Config);
            await JS.InvokeVoidAsync("preflightFiles.download", "autounattend.xml", xml, "application/xml");
        }
        catch (Exception ex)
        {
            _lastError = ex.Message;
        }
        finally
        {
            _downloading = false;
            StateHasChanged();
        }
    }
}
