@page "/wizard/guided/{Step:int}"
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Nav
@inject ModeService Mode

@*
    Out-of-range Step (e.g. /wizard/guided/0 or /wizard/guided/999) → render
    the global NotFound page inline. The :int constraint already filters
    non-numeric values so the Router's <NotFound> handles those, but the
    range check has to live here.
*@
@if (Step < 1 || Step > TotalSteps)
{
    <NotFound />
}
else
{
    <PageTitle>@L["Wizard.Guided.Title"] · Step @Step</PageTitle>

    <FluentStack Orientation="Orientation.Vertical" HorizontalGap="24" Style="padding: 48px 16px; max-width: 1080px; margin: 0 auto;">

    @*
        Step indicator - "Step N of M" label on the left, a plane-on-runway
        progress strip on the right. The strip reuses the same visual motif as
        the loading screen: wavy track, progressive accent-gradient trail that
        fades toward its tail, and the plane glyph planted at the current
        progress percentage (offset-path along the same S-curve).
    *@
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12" VerticalAlignment="VerticalAlignment.Center">
        <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
            @(string.Format(L["Wizard.Guided.StepOf"].Value, Step, TotalSteps))
        </FluentLabel>
        <FluentSpacer />
        <div class="pf-step-runway" style="--pf-step-progress: @(Step * 100 / TotalSteps)%;"
             role="progressbar"
             aria-valuenow="@Step"
             aria-valuemin="1"
             aria-valuemax="@TotalSteps"
             aria-label="@(string.Format(L["Wizard.Guided.StepOf"].Value, Step, TotalSteps))">
            <svg class="pf-step-runway__wave" width="240" height="36" viewBox="0 0 240 36" aria-hidden="true" preserveAspectRatio="none">
                <defs>
                    <linearGradient id="pfStepTrailGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="0%" stop-color="var(--pf-accent)" />
                        <stop offset="100%" stop-color="var(--pf-accent-strong, var(--pf-accent))" />
                    </linearGradient>
                </defs>
                <path class="pf-step-runway__track" d="M 2 18 Q 32 4, 62 18 T 122 18 T 182 18 T 238 18" />
                <path class="pf-step-runway__trail" d="M 2 18 Q 32 4, 62 18 T 122 18 T 182 18 T 238 18" />
            </svg>
            <svg class="pf-step-runway__plane" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="currentColor"
                      d="M21 16v-2l-8-5V3.5A1.5 1.5 0 0 0 11.5 2A1.5 1.5 0 0 0 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1l3.5 1v-1.5L13 19v-5.5z" />
            </svg>
        </div>
    </FluentStack>

    @switch (Step)
    {
        case 1:
            <Step_Language />
            break;
        case 2:
            <Step_Disk />
            break;
        case 3:
            <Step_Users />
            break;
        case 4:
            <Step_Privacy />
            break;
        case 5:
            <Step_Finish />
            break;
        // No default needed - the @if guard at the top of the component
        // already redirects out-of-range Step values to <NotFound />.
    }

    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
        @if (Step > 1)
        {
            <FluentButton Appearance="Appearance.Outline" OnClick="Previous">← @L["Common.Back"]</FluentButton>
        }
        <FluentSpacer />
        @if (Step < TotalSteps)
        {
            <FluentButton Appearance="Appearance.Accent" OnClick="Next">@L["Common.Next"] →</FluentButton>
        }
        else
        {
            <FluentButton Appearance="Appearance.Accent" OnClick='@(() => Nav.NavigateTo("wizard/review"))'>
                @L["Wizard.Guided.Finish"] →
            </FluentButton>
        }
    </FluentStack>

    </FluentStack>
}

@code {
    private const int TotalSteps = 5;

    [Parameter] public int Step { get; set; } = 1;

    private void Previous() => Nav.NavigateTo($"wizard/guided/{Step - 1}");
    private void Next() => Nav.NavigateTo($"wizard/guided/{Step + 1}");
}
