@page "/wizard"
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Nav

<PageTitle>@L["Wizard.Title"] · preflight.xml</PageTitle>

<FluentStack Orientation="Orientation.Vertical" HorizontalGap="24" Style="padding: 48px 16px; max-width: 720px; margin: 0 auto;">

    <FluentLabel Typo="Typography.PageTitle">✈️ @L["Wizard.Title"]</FluentLabel>
    <FluentLabel Typo="Typography.Subject">@L["Wizard.Entry.Prompt"]</FluentLabel>

    <FluentGrid Spacing="3" Justify="JustifyContent.Center" Style="margin-top: 16px;">
        <FluentGridItem xs="12" sm="6">
            <FluentCard Style="cursor: pointer; height: 100%;" @onclick='@(() => Nav.NavigateTo("/wizard/guided/1"))'>
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8" Style="padding: 24px;">
                    <div style="font-size: 40px;">🧭</div>
                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@L["Wizard.Guided.Title"]</FluentLabel>
                    <FluentLabel Typo="Typography.Body">@L["Wizard.Guided.Description"]</FluentLabel>
                    <FluentButton Appearance="Appearance.Accent" OnClick='@(() => Nav.NavigateTo("/wizard/guided/1"))'>
                        @L["Wizard.Guided.Cta"]
                    </FluentButton>
                </FluentStack>
            </FluentCard>
        </FluentGridItem>

        <FluentGridItem xs="12" sm="6">
            <FluentCard Style="cursor: pointer; height: 100%;" @onclick='@(() => Nav.NavigateTo("/wizard/presets"))'>
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8" Style="padding: 24px;">
                    <div style="font-size: 40px;">🎛️</div>
                    <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">@L["Wizard.Presets.Title"]</FluentLabel>
                    <FluentLabel Typo="Typography.Body">@L["Wizard.Presets.Description"]</FluentLabel>
                    <FluentButton Appearance="Appearance.Accent" OnClick='@(() => Nav.NavigateTo("/wizard/presets"))'>
                        @L["Wizard.Presets.Cta"]
                    </FluentButton>
                </FluentStack>
            </FluentCard>
        </FluentGridItem>
    </FluentGrid>

    <div>
        <FluentAnchor Href="/" Appearance="Appearance.Hypertext">← @L["Common.BackToHome"]</FluentAnchor>
    </div>

</FluentStack>
