@inject IStringLocalizer<SharedResources> L

@*
    Region wizard step. The section's own SectionView header (h2 + subtitle +
    "Read in Docs" link) carries framing - we don't layer a wizard-specific
    H3 on top because that doubled the heading in every step.
*@

<FluentCard Style="padding: 24px;">
    <SectionView Section="@RegionSection.Definition"
                 ViewMode="SectionView.SectionMode.Advanced"
                 OptionIds="@(new[] { "display-lang", "input-lang", "home-location" })" />
</FluentCard>
