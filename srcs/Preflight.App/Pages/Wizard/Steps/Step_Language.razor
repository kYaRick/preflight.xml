@inject IStringLocalizer<SharedResources> L

@* Wizard flavor of the Region section — narrative framing with step title + description,
   then the same controls Advanced uses, sourced from a single RegionSection.Definition
   (option B from the Phase 3 design). Adding a field to the section definition surfaces
   it here automatically; no duplicated dropdown setup. *@

<FluentCard Style="padding: 24px;">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
        <FluentLabel Typo="Typography.H3">🌍 @L["Step.Language.Title"]</FluentLabel>
        <FluentLabel Typo="Typography.Body">@L["Step.Language.Description"]</FluentLabel>

        <SectionView Section="@RegionSection.Definition"
                     ViewMode="SectionView.SectionMode.Advanced"
                     OptionIds="@(new[] { "display-lang", "input-lang", "home-location" })" />
    </FluentStack>
</FluentCard>
