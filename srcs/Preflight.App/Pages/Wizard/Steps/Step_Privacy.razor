@inject IStringLocalizer<SharedResources> L

@*
    Privacy wizard step. Combines two sections the guided flow cares about:
    Express-settings (the OOBE privacy screen) shown with its own header so the
    user knows which section they're in, plus a curated subset of Setup toggles
    rendered headerless so they read as a continuation of the Privacy block.
*@

<FluentCard Style="padding: 24px;">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="20">
        <SectionView Section="@ExpressSettingsSection.Definition"
                     ViewMode="SectionView.SectionMode.Advanced" />

        <SectionView Section="@SetupSettingsSection.Definition"
                     ViewMode="SectionView.SectionMode.Advanced"
                     ShowHeader="false"
                     OptionIds="@(new[] { "bypass-requirements-check", "bypass-network-check", "keep-sensitive-files" })" />
    </FluentStack>
</FluentCard>
