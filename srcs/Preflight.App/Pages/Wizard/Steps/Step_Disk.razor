@inject IStringLocalizer<SharedResources> L

<FluentCard Style="padding: 24px;">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
        <FluentLabel Typo="Typography.H3">💽 @L["Step.Disk.Title"]</FluentLabel>
        <FluentLabel Typo="Typography.Body">@L["Step.Disk.Description"]</FluentLabel>
        <FluentMessageBar Intent="MessageIntent.Info" AllowDismiss="false">@L["Common.ComingInPhase3"]</FluentMessageBar>
    </FluentStack>
</FluentCard>
