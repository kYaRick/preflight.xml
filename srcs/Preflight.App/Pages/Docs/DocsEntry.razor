@page "/docs/{Slug}"
@using Preflight.App.Content
@using System.Globalization
@using Markdig
@inject IStringLocalizer<SharedResources> L
@inject HttpClient Http

<PageTitle>@_name · @L["Docs.Title"]</PageTitle>

<div class="pf-docs-entry" style="padding: 16px; max-width: 1400px; margin: 0 auto;">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" VerticalAlignment="VerticalAlignment.Center">
        <FluentAnchor Href="/docs" Appearance="Appearance.Outline">← @L["Docs.BackToIndex"]</FluentAnchor>
        <FluentSpacer />
        <FluentAnchor Href="/" Appearance="Appearance.Lightweight">@L["Common.BackToHome"]</FluentAnchor>
    </FluentStack>

    <FluentGrid Spacing="3" Style="margin-top: 12px; align-items: flex-start;">

        <!-- Sidebar: sections grouped by install phase, matching /advanced. -->
        <FluentGridItem xs="12" md="3">
            <FluentCard Class="pf-nav-card" Style="padding: 6px; position: sticky; top: 16px;">
                <nav class="pf-nav-groups" aria-label="@L[@"Docs.Title"]">
                    @foreach (var group in SectionRegistry.Groups)
                    {
                        var isOpen = group.SectionIds.Contains(Slug, StringComparer.Ordinal);
                        <details class="pf-nav-group" open="@isOpen">
                            <summary class="pf-nav-group__summary">
                                <span class="pf-nav-group__icon" aria-hidden="true">@group.Emoji</span>
                                <span class="pf-nav-group__title">@L[group.TitleKey]</span>
                                <span class="pf-nav-group__count">@group.SectionIds.Count</span>
                            </summary>
                            <ul class="pf-nav-group__list">
                                @foreach (var id in group.SectionIds)
                                {
                                    <li>
                                        <NavLink class="pf-nav-group__link" href="@($"/docs/{id}")" Match="NavLinkMatch.All">
                                            @L[$"Advanced.Section.{id}"]
                                        </NavLink>
                                    </li>
                                }
                            </ul>
                        </details>
                    }
                </nav>
            </FluentCard>
        </FluentGridItem>

        <!-- Main content -->
        <FluentGridItem xs="12" md="9">
            <FluentLabel Typo="Typography.PageTitle">@_name</FluentLabel>
            <FluentLabel Typo="Typography.Body" Style="margin: 4px 0 16px 0; opacity: 0.8;">@_description</FluentLabel>

            @if (_section is not null)
            {
                <SectionView Section="@_section" ViewMode="SectionView.SectionMode.Docs" ShowHeader="false" />
            }
            else if (_articleHtml is not null)
            {
                <section class="pf-section__intro">
                    @((MarkupString)_articleHtml)
                </section>
            }
            else
            {
                <FluentMessageBar Intent="MessageIntent.Info" AllowDismiss="false">
                    @L["Docs.Entry.ComingSoon"]
                </FluentMessageBar>
            }
        </FluentGridItem>
    </FluentGrid>
</div>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private string _name = "";
    private string _description = "";
    private SectionDefinition? _section;
    private string? _articleHtml;

    protected override async Task OnParametersSetAsync()
    {
        var isKnown = SectionRegistry.AllSectionIds.Contains(Slug, StringComparer.Ordinal);
        _section = SectionRegistry.TryGet(Slug);
        _articleHtml = isKnown ? await TryRenderMarkdownAsync($"content/sections/{Slug}.{{locale}}.md") : null;

        if (!isKnown)
        {
            _name = L["Docs.Entry.Unknown"];
            _description = L["Docs.Entry.UnknownDescription"];
            return;
        }

        _name = L[$"Advanced.Section.{Slug}"];
        var subtitle = L[$"Section.{Slug}.Subtitle"];
        _description = subtitle.ResourceNotFound
            ? L["Docs.Entry.ComingSoon"]
            : subtitle.Value;
    }

    private async Task<string?> TryRenderMarkdownAsync(string pathTemplate)
    {
        var locale = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        var path = pathTemplate.Replace("{locale}", locale, StringComparison.Ordinal);

        try
        {
            var md = await Http.GetStringAsync(path);
            return Markdown.ToHtml(md);
        }
        catch (HttpRequestException)
        {
            if (locale != "en")
            {
                try
                {
                    var fallback = await Http.GetStringAsync(pathTemplate.Replace("{locale}", "en", StringComparison.Ordinal));
                    return Markdown.ToHtml(fallback);
                }
                catch (HttpRequestException)
                {
                    return null;
                }
            }

            return null;
        }
    }
}
