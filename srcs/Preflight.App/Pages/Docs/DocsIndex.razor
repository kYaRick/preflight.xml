@page "/docs"
@using Preflight.App.Content
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Docs.Title"] · preflight.xml</PageTitle>

<div style="padding: 24px 16px; max-width: 1400px; margin: 0 auto;">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" VerticalAlignment="VerticalAlignment.Center">
        <FluentLabel Typo="Typography.PageTitle">📖 @L["Docs.Title"]</FluentLabel>
        <FluentSpacer />
        <FluentAnchor Href="/" Appearance="Appearance.Outline">← @L["Common.BackToHome"]</FluentAnchor>
    </FluentStack>

    <FluentLabel Typo="Typography.Body" Style="margin: 8px 0 24px 0;">@L["Docs.Subtitle"]</FluentLabel>

    <FluentGrid Spacing="3">

        <!-- Sidebar: category list -->
        <FluentGridItem xs="12" md="3">
            <FluentCard Style="padding: 8px;">
                <FluentNavMenu>
                    @foreach (var topic in _topics)
                    {
                        <FluentNavLink Href="@($"/docs/{topic.Slug}")" Match="NavLinkMatch.All">
                            @L[$"Advanced.Section.{topic.Slug}"]
                        </FluentNavLink>
                    }
                </FluentNavMenu>
            </FluentCard>
        </FluentGridItem>

        <!-- Main: topic cards grid -->
        <FluentGridItem xs="12" md="9">
            <FluentGrid Spacing="2">
                @foreach (var topic in _topics)
                {
                    <FluentGridItem xs="12" sm="6" lg="4">
                        <FluentCard Class="pf-card--interactive" Style="padding: 20px; height: 100%;"
                                    @onclick="() => GoToTopic(topic.Slug)">
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">
                                    @L[$"Advanced.Section.{topic.Slug}"]
                                </FluentLabel>
                                <FluentLabel Typo="Typography.Body">
                                    @GetSectionSubtitle(topic.Slug)
                                </FluentLabel>
                            </FluentStack>
                        </FluentCard>
                    </FluentGridItem>
                }
            </FluentGrid>
        </FluentGridItem>

    </FluentGrid>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private void GoToTopic(string slug) => Nav.NavigateTo($"/docs/{slug}");

    private sealed record DocTopic(string Slug);

    private static readonly IReadOnlyList<DocTopic> _topics =
        SectionRegistry.AllSectionIds.Select(static id => new DocTopic(id)).ToArray();

    private string GetSectionSubtitle(string slug)
    {
        var subtitle = L[$"Section.{slug}.Subtitle"];
        return subtitle.ResourceNotFound ? L["Docs.Entry.ComingSoon"] : subtitle.Value;
    }
}
