@page "/docs"
@using Preflight.App.Content
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Docs.Title"] · preflight.xml</PageTitle>

<div style="padding: 24px 16px; max-width: 1400px; margin: 0 auto;">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" VerticalAlignment="VerticalAlignment.Center">
        <FluentLabel Typo="Typography.PageTitle">📖 @L["Docs.Title"]</FluentLabel>
        <FluentSpacer />
        <FluentAnchor Href="/" Appearance="Appearance.Outline">← @L["Common.BackToHome"]</FluentAnchor>
    </FluentStack>

    <FluentLabel Typo="Typography.Body" Style="margin: 8px 0 16px 0;">@L["Docs.Subtitle"]</FluentLabel>

    @*
        Inline search that filters the cards grid by title + subtitle (case
        insensitive). A plain input, no wrapping card, no counter - just enough
        surface for a user to narrow the list without adding visual weight.
    *@
    <div class="pf-nav-search pf-docs-search">
        <span class="pf-nav-search__icon" aria-hidden="true">🔎</span>
        <input type="search"
               class="pf-nav-search__input"
               placeholder="@L[@"Docs.SidebarSearch"]"
               value="@_filter"
               @oninput="OnFilterChanged"
               aria-label="@L[@"Docs.SidebarSearch"]" />
        @if (!string.IsNullOrEmpty(_filter))
        {
            <button type="button" class="pf-nav-search__clear" aria-label="Clear" @onclick="ClearFilter">✕</button>
        }
    </div>

    <FluentGrid Spacing="2">
        @foreach (var topic in _filteredTopics)
        {
            <FluentGridItem xs="12" sm="6" md="4" lg="3">
                <FluentCard Class="pf-card--interactive" Style="padding: 20px; height: 100%;"
                            @onclick="() => GoToTopic(topic.Slug)">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">
                            @L[$"Advanced.Section.{topic.Slug}"]
                        </FluentLabel>
                        <FluentLabel Typo="Typography.Body">
                            @GetSectionSubtitle(topic.Slug)
                        </FluentLabel>
                    </FluentStack>
                </FluentCard>
            </FluentGridItem>
        }
    </FluentGrid>

    @if (_filteredTopics.Count == 0)
    {
        <FluentMessageBar Intent="MessageIntent.Info" AllowDismiss="false" Style="margin-top: 16px;">
            @string.Format(L[@"Docs.NoResults"].Value, _filter)
        </FluentMessageBar>
    }
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private void GoToTopic(string slug) => Nav.NavigateTo($"/docs/{slug}");

    private sealed record DocTopic(string Slug);

    private static readonly IReadOnlyList<DocTopic> _topics =
        SectionRegistry.AllSectionIds.Select(static id => new DocTopic(id)).ToArray();

    private string _filter = "";
    private IReadOnlyList<DocTopic> _filteredTopics = _topics;

    private void OnFilterChanged(ChangeEventArgs e)
    {
        _filter = (e.Value as string) ?? "";
        RecomputeFilter();
    }

    private void ClearFilter()
    {
        _filter = "";
        RecomputeFilter();
    }

    private void RecomputeFilter()
    {
        if (string.IsNullOrWhiteSpace(_filter))
        {
            _filteredTopics = _topics;
            return;
        }
        var needle = _filter.Trim();
        _filteredTopics = _topics.Where(t =>
        {
            if (t.Slug.Contains(needle, StringComparison.OrdinalIgnoreCase)) return true;
            var label = (string)L[$"Advanced.Section.{t.Slug}"];
            if (label.Contains(needle, StringComparison.OrdinalIgnoreCase)) return true;
            var subtitle = GetSectionSubtitle(t.Slug);
            return subtitle.Contains(needle, StringComparison.OrdinalIgnoreCase);
        }).ToArray();
    }

    private string GetSectionSubtitle(string slug)
    {
        var subtitle = L[$"Section.{slug}.Subtitle"];
        return subtitle.ResourceNotFound ? L["Docs.Entry.ComingSoon"] : subtitle.Value;
    }
}
