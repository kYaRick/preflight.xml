@page "/docs"
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["Docs.Title"] · preflight.xml</PageTitle>

<div style="padding: 24px 16px; max-width: 1400px; margin: 0 auto;">
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" VerticalAlignment="VerticalAlignment.Center">
        <FluentLabel Typo="Typography.PageTitle">📖 @L["Docs.Title"]</FluentLabel>
        <FluentSpacer />
        <FluentAnchor Href="/" Appearance="Appearance.Outline">← @L["Common.BackToHome"]</FluentAnchor>
    </FluentStack>

    <FluentLabel Typo="Typography.Body" Style="margin: 8px 0 24px 0;">@L["Docs.Subtitle"]</FluentLabel>

    <FluentGrid Spacing="3">

        <!-- Sidebar: category list -->
        <FluentGridItem xs="12" md="3">
            <FluentCard Style="padding: 8px;">
                <FluentNavMenu>
                    @foreach (var topic in _topics)
                    {
                        <FluentNavLink Href="@($"/docs/{topic.Slug}")" Match="NavLinkMatch.All">
                            @topic.Icon @L[topic.NameKey]
                        </FluentNavLink>
                    }
                </FluentNavMenu>
            </FluentCard>
        </FluentGridItem>

        <!-- Main: topic cards grid -->
        <FluentGridItem xs="12" md="9">
            <FluentGrid Spacing="2">
                @foreach (var topic in _topics)
                {
                    <FluentGridItem xs="12" sm="6" lg="4">
                        <FluentCard Style="padding: 20px; cursor: pointer; height: 100%;"
                                    @onclick="() => GoToTopic(topic.Slug)">
                            <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                                <div style="font-size: 32px;">@topic.Icon</div>
                                <FluentLabel Typo="Typography.Subject" Weight="FontWeight.Bold">
                                    @L[topic.NameKey]
                                </FluentLabel>
                                <FluentLabel Typo="Typography.Body">
                                    @L[topic.DescriptionKey]
                                </FluentLabel>
                            </FluentStack>
                        </FluentCard>
                    </FluentGridItem>
                }
            </FluentGrid>
        </FluentGridItem>

    </FluentGrid>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private void GoToTopic(string slug) => Nav.NavigateTo($"/docs/{slug}");

    private sealed record DocTopic(string Slug, string Icon, string NameKey, string DescriptionKey);

    private static readonly DocTopic[] _topics =
    [
        new("region",    "🌍", "Docs.Topic.Region.Name",    "Docs.Topic.Region.Description"),
        new("disk",      "💽", "Docs.Topic.Disk.Name",      "Docs.Topic.Disk.Description"),
        new("users",     "👤", "Docs.Topic.Users.Name",     "Docs.Topic.Users.Description"),
        new("edition",   "🪟", "Docs.Topic.Edition.Name",   "Docs.Topic.Edition.Description"),
        new("privacy",   "🔒", "Docs.Topic.Privacy.Name",   "Docs.Topic.Privacy.Description"),
        new("security",  "🛡️", "Docs.Topic.Security.Name",  "Docs.Topic.Security.Description"),
        new("bloatware", "🧼", "Docs.Topic.Bloatware.Name", "Docs.Topic.Bloatware.Description"),
        new("tweaks",    "🔧", "Docs.Topic.Tweaks.Name",    "Docs.Topic.Tweaks.Description"),
        new("vm",        "🖥️", "Docs.Topic.Vm.Name",        "Docs.Topic.Vm.Description"),
    ];
}
