@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResources> L

<FluentDesignTheme @bind-Mode="_themeMode" StorageName="preflight.theme" />

<FluentLayout>
    <FluentHeader>
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="width: 100%;">
            <FluentLabel Typo="Typography.H4">✈️ preflight.xml</FluentLabel>
            <FluentSpacer />
            <ThemeSwitcher @bind-Mode="_themeMode" />
            <LanguageSwitcher />
        </FluentStack>
    </FluentHeader>

    <FluentStack Class="main" Orientation="Orientation.Horizontal" Width="100%">
        <FluentBodyContent Class="body-content">
            <div class="content">
                @Body
            </div>
        </FluentBodyContent>
    </FluentStack>

    <FluentFooter>
        <FluentLabel Typo="Typography.Body">
            @L["Footer.BuiltBy"]
            <FluentAnchor Href="https://github.com/kYaRick/preflight.xml" Appearance="Appearance.Hypertext" Target="_blank">
                kYaRick
            </FluentAnchor>
            · MIT
        </FluentLabel>
    </FluentFooter>
</FluentLayout>

@code {
    private DesignThemeModes _themeMode = DesignThemeModes.System;
}
