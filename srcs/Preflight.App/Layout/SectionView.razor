@using System.Globalization
@using System.Net.Http.Json
@using Markdig
@using Preflight.App.Models
@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Nav
@implements IDisposable

<div class="pf-section @(ViewMode == SectionMode.Docs ? "pf-section--docs" : "pf-section--advanced")">

    @if (ShowHeader)
    {
        <header class="pf-section__head">
            <h2 class="pf-section__title">@L[Section.TitleKey]</h2>
            <p class="pf-section__subtitle">@L[Section.SubtitleKey]</p>
            @if (ViewMode == SectionMode.Advanced)
            {
                <a class="pf-section__docs-link" href="@($"/docs/{Section.Id}")">@L["Section.Docs.Link"]</a>
            }
        </header>
    }

    @if (ViewMode == SectionMode.Docs && _introHtml is not null)
    {
        <section class="pf-section__intro">
            @((MarkupString)_introHtml)
        </section>
    }

    <section class="pf-section__options">
        @{
            string? currentGroup = null;
        }
        @foreach (var option in _filteredOptions)
        {
            // Respect master/child conditional visibility in Advanced (always render in Docs
            // so the full surface is documented).
            if (ViewMode == SectionMode.Advanced && option.VisibleWhen is not null && !option.VisibleWhen(ModeSvc.Config))
            {
                continue;
            }

            if (!string.Equals(option.GroupHeadingKey, currentGroup, StringComparison.Ordinal))
            {
                currentGroup = option.GroupHeadingKey;
                if (currentGroup is not null)
                {
                    <h4 class="pf-section__group-heading">@L[currentGroup]</h4>
                }
            }

            <div id="@option.Id" class="pf-option">
                <div class="pf-option__head">
                    <label class="pf-option__label" for="@($"opt-{option.Id}")">@L[option.LabelKey]</label>
                    @if (!string.IsNullOrEmpty(option.LearnMoreUrl))
                    {
                        <a class="pf-option__learn-more" href="@option.LearnMoreUrl" target="_blank" rel="noopener">@L["Section.LearnMore"]</a>
                    }
                </div>

                @if (option.DescriptionKey is not null
                     && (ViewMode == SectionMode.Docs || option.ShowDescriptionInAdvanced))
                {
                    <p class="pf-option__description">@L[option.DescriptionKey]</p>
                }

                @if (ViewMode == SectionMode.Advanced)
                {
                    @RenderControl(option)
                }
            </div>
        }
    </section>
</div>

@code {
    public enum SectionMode { Docs, Advanced }

    [Parameter, EditorRequired] public SectionDefinition Section { get; set; } = default!;
    [Parameter] public SectionMode ViewMode { get; set; } = SectionMode.Advanced;
    [Parameter] public bool ShowHeader { get; set; } = true;
    /// <summary>If non-null, restrict rendering to options whose Id matches (used by Wizard steps).</summary>
    [Parameter] public string[]? OptionIds { get; set; }

    private string? _introHtml;
    private IReadOnlyList<OptionDefinition> _filteredOptions = [];
    private readonly Dictionary<string, IReadOnlyList<DataEntry>> _jsonCache = new(StringComparer.Ordinal);

    private record DataEntry(string Id, string DisplayName);

    private string? _lastLoadedSectionId;

    protected override void OnInitialized()
    {
        if (ViewMode == SectionMode.Advanced)
            ModeSvc.StateChanged += OnConfigChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        _filteredOptions = OptionIds is null
            ? Section.Options
            : Section.Options.Where(o => OptionIds.Contains(o.Id, StringComparer.Ordinal)).ToArray();

        // Only hit HTTP when the section actually changes; parameter-set fires on every
        // re-render (including after every config mutation), and reloading the same JSON
        // on each keystroke is pure waste.
        if (_lastLoadedSectionId != Section.Id)
        {
            _lastLoadedSectionId = Section.Id;
            await LoadAsync();
        }
    }

    // ─── helpers ────────────────────────────────────────────────────

    // ModeService is injected under the name `Mode`, which collides with our enum alias.
    // Use an explicit getter via DI rather than renaming the parameter (the parameter name
    // is part of the component's public API via <SectionView Mode="..." />).
    [Inject] private ModeService ModeSvc { get; set; } = default!;

    private async Task LoadAsync()
    {
        _introHtml = await TryRenderMarkdownAsync(Section.IntroMarkdownPath);

        foreach (var option in _filteredOptions.Where(o => o.JsonSource is not null))
        {
            if (_jsonCache.ContainsKey(option.JsonSource!)) continue;
            try
            {
                var entries = await Http.GetFromJsonAsync<List<DataEntry>>(option.JsonSource!);
                if (entries is not null) _jsonCache[option.JsonSource!] = entries;
            }
            catch (Exception) { _jsonCache[option.JsonSource!] = []; }
        }

        StateHasChanged();
    }

    private async Task<string?> TryRenderMarkdownAsync(string pathTemplate)
    {
        var locale = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName; // "en" / "uk"
        var path = pathTemplate.Replace("{locale}", locale, StringComparison.Ordinal);
        try
        {
            var md = await Http.GetStringAsync(path);
            return Markdown.ToHtml(md);
        }
        catch (HttpRequestException)
        {
            if (locale != "en")
            {
                try
                {
                    var fallback = await Http.GetStringAsync(pathTemplate.Replace("{locale}", "en", StringComparison.Ordinal));
                    return Markdown.ToHtml(fallback);
                }
                catch (HttpRequestException) { /* no content - fine, intro is optional */ }
            }
            return null;
        }
    }

    private void OnConfigChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        if (ViewMode == SectionMode.Advanced)
            ModeSvc.StateChanged -= OnConfigChanged;
    }

    // ─── control rendering ─────────────────────────────────────────

    private RenderFragment RenderControl(OptionDefinition option) => builder =>
    {
        switch (option.Kind)
        {
            case OptionKind.Dropdown:
                RenderDropdown(builder, option);
                break;
            case OptionKind.Text:
                RenderTextInput(builder, option);
                break;
            case OptionKind.Checkbox:
                RenderCheckbox(builder, option);
                break;
            case OptionKind.Radio:
                RenderRadio(builder, option);
                break;
            case OptionKind.CheckboxGroup:
                RenderCheckboxGroup(builder, option);
                break;
            case OptionKind.Number:
                RenderNumber(builder, option);
                break;
            case OptionKind.Textarea:
                RenderTextarea(builder, option);
                break;
        }
    };

    private void RenderDropdown(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder, OptionDefinition option)
    {
        var currentValue = option.GetString?.Invoke(ModeSvc.Config) ?? "";
        var entries = option.JsonSource is not null && _jsonCache.TryGetValue(option.JsonSource, out var cached)
            ? cached
            : option.InlineValues?.Select(v => new DataEntry(v.Value, L[v.DisplayKey])).ToList() as IReadOnlyList<DataEntry>
              ?? [];

        var i = 0;
        builder.OpenComponent<FluentSelect<string>>(i++);
        builder.AddAttribute(i++, "Class", "pf-select");
        builder.AddAttribute(i++, "Value", currentValue);
        builder.AddAttribute(i++, "ValueChanged", EventCallback.Factory.Create<string>(this, v =>
        {
            option.SetString?.Invoke(ModeSvc.Config, v);
            ModeSvc.NotifyConfigChanged();
        }));
        builder.AddAttribute(i++, "Width", "100%");
        builder.AddAttribute(i++, "ChildContent", (RenderFragment)(child =>
        {
            var idx = 0;
            foreach (var entry in entries)
            {
                child.OpenComponent<FluentOption<string>>(idx++);
                child.AddAttribute(idx++, "Value", entry.Id);
                child.AddAttribute(idx++, "Selected", entry.Id == currentValue);
                child.AddAttribute(idx++, "ChildContent", (RenderFragment)(c => c.AddContent(0, entry.DisplayName)));
                child.CloseComponent();
            }
        }));
        builder.CloseComponent();
    }

    private void RenderTextInput(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder, OptionDefinition option)
    {
        var i = 0;
        builder.OpenComponent<FluentTextField>(i++);
        builder.AddAttribute(i++, "Value", option.GetString?.Invoke(ModeSvc.Config));
        builder.AddAttribute(i++, "ValueChanged", EventCallback.Factory.Create<string>(this, v =>
        {
            option.SetString?.Invoke(ModeSvc.Config, v);
            ModeSvc.NotifyConfigChanged();
        }));
        builder.CloseComponent();
    }

    private void RenderCheckbox(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder, OptionDefinition option)
    {
        var i = 0;
        builder.OpenComponent<FluentCheckbox>(i++);
        builder.AddAttribute(i++, "Value", option.GetBool?.Invoke(ModeSvc.Config) ?? false);
        builder.AddAttribute(i++, "ValueChanged", EventCallback.Factory.Create<bool>(this, v =>
        {
            option.SetBool?.Invoke(ModeSvc.Config, v);
            ModeSvc.NotifyConfigChanged();
        }));
        builder.CloseComponent();
    }

    private void RenderRadio(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder, OptionDefinition option)
    {
        var currentValue = option.GetString?.Invoke(ModeSvc.Config) ?? "";
        var entries = option.InlineValues ?? [];

        var i = 0;
        builder.OpenElement(i++, "div");
        builder.AddAttribute(i++, "class", "pf-radio-group");
        builder.AddAttribute(i++, "role", "radiogroup");

        foreach (var entry in entries)
        {
            var entryValue = entry.Value;
            var isChecked = string.Equals(currentValue, entryValue, StringComparison.Ordinal);

            builder.OpenElement(i++, "label");
            builder.AddAttribute(i++, "class", "pf-radio");

            builder.OpenElement(i++, "input");
            builder.AddAttribute(i++, "type", "radio");
            builder.AddAttribute(i++, "name", $"opt-{option.Id}");
            builder.AddAttribute(i++, "value", entryValue);
            builder.AddAttribute(i++, "checked", isChecked);
            builder.AddAttribute(i++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, _ =>
            {
                option.SetString?.Invoke(ModeSvc.Config, entryValue);
                ModeSvc.NotifyConfigChanged();
            }));
            builder.CloseElement();

            builder.OpenElement(i++, "span");
            builder.AddAttribute(i++, "class", "pf-radio__label");
            builder.AddContent(i++, L[entry.DisplayKey]);
            builder.CloseElement();

            builder.CloseElement();
        }

        builder.CloseElement();
    }

    private void RenderCheckboxGroup(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder, OptionDefinition option)
    {
        // Data source: inline values (preferred for enum-style sets) or JSON loaded at OnParametersSet
        // (used by large bloatware/icon/component lists).
        IReadOnlyList<(string Value, string DisplayText)> rows;
        if (option.InlineValues is { } inline && inline.Count > 0)
        {
            rows = inline.Select(v => (v.Value, (string)L[v.DisplayKey])).ToList();
        }
        else if (option.JsonSource is not null && _jsonCache.TryGetValue(option.JsonSource, out var cached))
        {
            rows = cached.Select(e => (e.Id, e.DisplayName)).ToList();
        }
        else
        {
            rows = [];
        }

        // Membership lookup: prefer the per-item delegate (Group-5 pattern), fall back to the
        // whole-set getter (Group-7 legacy) if only that one is supplied.
        var legacySet = option.GetStringSet?.Invoke(ModeSvc.Config);

        var i = 0;
        builder.OpenElement(i++, "div");
        builder.AddAttribute(i++, "class", "pf-checkbox-group");

        foreach (var row in rows)
        {
            var value = row.Value;
            var isChecked = option.IsItemSelected?.Invoke(ModeSvc.Config, value)
                            ?? legacySet?.Contains(value)
                            ?? false;

            builder.OpenElement(i++, "label");
            builder.AddAttribute(i++, "class", "pf-checkbox-row");

            builder.OpenComponent<FluentCheckbox>(i++);
            builder.AddAttribute(i++, "Value", isChecked);
            builder.AddAttribute(i++, "ValueChanged", EventCallback.Factory.Create<bool>(this, v =>
            {
                if (option.SetItemSelected is not null)
                    option.SetItemSelected.Invoke(ModeSvc.Config, value, v);
                else
                    option.SetStringSetItem?.Invoke(ModeSvc.Config, value, v);
                ModeSvc.NotifyConfigChanged();
            }));
            builder.CloseComponent();

            builder.OpenElement(i++, "span");
            builder.AddAttribute(i++, "class", "pf-checkbox-row__label");
            builder.AddContent(i++, row.DisplayText);
            builder.CloseElement();

            builder.CloseElement();
        }

        builder.CloseElement();
    }

    private void RenderNumber(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder, OptionDefinition option)
    {
        var current = option.GetInt?.Invoke(ModeSvc.Config) ?? 0;

        var i = 0;
        builder.OpenComponent<FluentNumberField<int>>(i++);
        builder.AddAttribute(i++, "Value", current);
        if (option.Min is not null) builder.AddAttribute(i++, "Min", option.Min.Value);
        if (option.Max is not null) builder.AddAttribute(i++, "Max", option.Max.Value);
        builder.AddAttribute(i++, "ValueChanged", EventCallback.Factory.Create<int>(this, v =>
        {
            option.SetInt?.Invoke(ModeSvc.Config, v);
            ModeSvc.NotifyConfigChanged();
        }));
        builder.CloseComponent();
    }

    private void RenderTextarea(Microsoft.AspNetCore.Components.Rendering.RenderTreeBuilder builder, OptionDefinition option)
    {
        var i = 0;
        builder.OpenComponent<FluentTextArea>(i++);
        builder.AddAttribute(i++, "Value", option.GetString?.Invoke(ModeSvc.Config) ?? "");
        // Rows: explicit `Rows` override wins; otherwise fall back to `TextareaRows` (default 6).
        builder.AddAttribute(i++, "Rows", option.Rows ?? option.TextareaRows);
        builder.AddAttribute(i++, "Class", "pf-textarea");
        var placeholder = option.PlaceholderKey is not null ? (string)L[option.PlaceholderKey] : option.Placeholder;
        if (!string.IsNullOrEmpty(placeholder))
            builder.AddAttribute(i++, "Placeholder", placeholder);
        if (option.Monospace)
            builder.AddAttribute(i++, "Style", "width: 100%; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;");
        builder.AddAttribute(i++, "ValueChanged", EventCallback.Factory.Create<string>(this, v =>
        {
            option.SetString?.Invoke(ModeSvc.Config, v);
            ModeSvc.NotifyConfigChanged();
        }));
        builder.CloseComponent();
    }
}
