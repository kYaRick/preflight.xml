@inject CultureService Culture

<FluentSelect TOption="string"
              Value="@_current"
              ValueChanged="OnChanged"
              Width="120px"
              aria-label="Language">
    <FluentOption Value="en">🇬🇧 English</FluentOption>
    <FluentOption Value="uk">🇺🇦 Українська</FluentOption>
</FluentSelect>

@code {
    private string _current = "en";

    protected override void OnInitialized()
    {
        _current = CultureService.Current.TwoLetterISOLanguageName;
    }

    private async Task OnChanged(string value)
    {
        if (string.IsNullOrEmpty(value) || value == _current) return;
        _current = value;
        await Culture.SetAsync(value);
    }
}
