@using System.Net.Http.Json
@using Preflight.App.Models
@implements IDisposable
@inject ModeService Mode
@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

@* Desktop-icons advanced view. Mode radio + independent DeleteEdge checkbox come from the
   shared section definition; the per-icon checkbox grid is only shown when Mode == Specific
   and is populated from data/desktop-icons.json on first render. *@
<SectionView Section="@DesktopIconsSection.Definition"
             ViewMode="SectionView.SectionMode.Advanced"
             ShowHeader="false"
             OptionIds="@VisibleOptionIds()" />

@if (Mode.Config.DesktopIcons.Mode == DesktopIconMode.Specific)
{
    <div class="pf-option" style="margin-top: 16px;">
        <div class="pf-option__head">
            <label class="pf-option__label">@L["DesktopIcons.VisibleIcons.Label"]</label>
        </div>
        <p class="pf-option__description">@L["DesktopIcons.VisibleIcons.Description"]</p>
        <div class="pf-checkbox-group" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 8px 16px; margin-top: 8px;">
            @foreach (var icon in _icons)
            {
                var id = icon.Id;
                <FluentCheckbox Value="@IsVisible(id)"
                                ValueChanged="@(v => SetVisible(id, v))"
                                Label="@icon.DisplayName" />
            }
        </div>
    </div>
}

@code {
    // The mode radio + the DeleteEdge checkbox are the only two rendered unconditionally;
    // the icon grid lives in this razor so SectionView doesn't see it.
    private static readonly string[] AllIds = ["mode", "delete-edge-desktop-icon"];

    private string[] VisibleOptionIds() => AllIds;

    private record DesktopIconEntry(string Id, string DisplayName);

    private IReadOnlyList<DesktopIconEntry> _icons = [];

    protected override async Task OnInitializedAsync()
    {
        Mode.StateChanged += OnChanged;
        try
        {
            var entries = await Http.GetFromJsonAsync<List<DesktopIconEntry>>("data/desktop-icons.json");
            if (entries is not null) _icons = entries;
        }
        // Fetch failure → empty list; the user sees "no icons to pick" rather than a crash.
        catch { _icons = []; }
    }

    private bool IsVisible(string id) => Mode.Config.DesktopIcons.VisibleIcons.Contains(id);

    private void SetVisible(string id, bool value)
    {
        if (value) Mode.Config.DesktopIcons.VisibleIcons.Add(id);
        else Mode.Config.DesktopIcons.VisibleIcons.Remove(id);
        Mode.NotifyConfigChanged();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Mode.StateChanged -= OnChanged;
}
