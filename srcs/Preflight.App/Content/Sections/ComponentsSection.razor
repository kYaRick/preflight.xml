@using System.Net.Http.Json
@using Preflight.App.Models
@inject IStringLocalizer<SharedResources> L
@inject HttpClient Http
@inject ModeService Mode
@implements IDisposable

@*
    XML components section. Users inject raw autounattend child elements into a
    chosen component + pass combination. Empty by default; rows are added on
    demand via "Add component" just like Custom scripts. Removing a row deletes
    it from the config entirely (not just clears its fields), so an abandoned
    row doesn't sit in memory waiting to be noticed.
*@

<div class="pf-section pf-section--advanced">
    <header class="pf-section__head">
        <h2 class="pf-section__title">@L["Advanced.Section.components"]</h2>
        <p class="pf-section__subtitle">@L["Section.components.Subtitle"]</p>
    </header>

    <p class="pf-option__description">@L["Components.Help"]</p>

    <div class="pf-components">
        @if (Mode.Config.Components.Entries.Count == 0)
        {
            <div class="pf-scripts-phase__empty">@L["Components.Empty"]</div>
        }

        @for (var i = 0; i < Mode.Config.Components.Entries.Count; i++)
        {
            var slotIndex = i;
            var entry = Mode.Config.Components.Entries[slotIndex];

            <div class="pf-component-slot">
                <div class="pf-component-slot__head">
                    <span class="pf-component-slot__num">#@(slotIndex + 1)</span>
                    <label class="pf-option__label" for="@($"comp-id-{slotIndex}")">@L["Components.ComponentId.Label"]</label>
                    <FluentSpacer />
                    <FluentButton Appearance="Appearance.Stealth"
                                  OnClick="@(() => RemoveSlot(slotIndex))"
                                  Title="@L["Components.Remove"]"
                                  aria-label="@L["Components.Remove"]">
                        ✕
                    </FluentButton>
                </div>
                <FluentSelect TOption="string"
                              Value="@(entry.ComponentId ?? string.Empty)"
                              ValueChanged="@(v => OnComponentIdChanged(slotIndex, v))"
                              Width="100%">
                    @foreach (var opt in _componentOptions)
                    {
                        <FluentOption TOption="string" Value="@opt.Id" Selected="@(opt.Id == (entry.ComponentId ?? string.Empty))">@opt.DisplayName</FluentOption>
                    }
                </FluentSelect>

                <label class="pf-option__label" style="margin-top: 12px;">@L["Components.Xml.Label"]</label>
                <CodeEditor Language="xml"
                            Rows="8"
                            Value="@(entry.Xml ?? string.Empty)"
                            ValueChanged="@(v => OnXmlChanged(slotIndex, v))"
                            Placeholder="@L["Components.Xml.Placeholder"]" />
            </div>
        }

        <FluentButton Appearance="Appearance.Outline" OnClick="AddSlot" Style="align-self: flex-start;">
            <span aria-hidden="true" style="margin-right: 4px;">＋</span> @L["Components.Add"]
        </FluentButton>
    </div>
</div>

@code {
    public sealed record ComponentEntry(string Id, string DisplayName);

    private IReadOnlyList<ComponentEntry> _componentOptions = [];

    protected override async Task OnInitializedAsync()
    {
        Mode.StateChanged += OnStateChanged;
        await LoadComponentsAsync();
    }

    private async Task LoadComponentsAsync()
    {
        try
        {
            var entries = await Http.GetFromJsonAsync<List<ComponentEntry>>("data/components.json");
            if (entries is not null)
            {
                // Prepend an empty "not selected" option so a slot can be explicitly cleared.
                var list = new List<ComponentEntry> { new(string.Empty, L["Components.None"]) };
                list.AddRange(entries);
                _componentOptions = list;
                StateHasChanged();
            }
        }
        catch (HttpRequestException)
        {
            _componentOptions = [new(string.Empty, L["Components.None"])];
        }
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Mode.StateChanged -= OnStateChanged;
    }

    private void AddSlot()
    {
        Mode.Config.Components.Entries.Add(new XmlComponentEntry());
        Mode.NotifyConfigChanged();
    }

    private void RemoveSlot(int slotIndex)
    {
        if (slotIndex < 0 || slotIndex >= Mode.Config.Components.Entries.Count) return;
        Mode.Config.Components.Entries.RemoveAt(slotIndex);
        Mode.NotifyConfigChanged();
    }

    private void OnComponentIdChanged(int slotIndex, string? value)
    {
        if (slotIndex < 0 || slotIndex >= Mode.Config.Components.Entries.Count) return;
        Mode.Config.Components.Entries[slotIndex].ComponentId = string.IsNullOrEmpty(value) ? null : value;
        Mode.NotifyConfigChanged();
    }

    private void OnXmlChanged(int slotIndex, string? value)
    {
        if (slotIndex < 0 || slotIndex >= Mode.Config.Components.Entries.Count) return;
        Mode.Config.Components.Entries[slotIndex].Xml = value;
        Mode.NotifyConfigChanged();
    }
}
