@using Preflight.App.Models
@inject IStringLocalizer<SharedResources> L
@inject ModeService ModeSvc
@implements IDisposable

@*
    Custom Advanced layout for the "Source image" section - IInstallFromSettings
    has three disjoint shapes; show only the field matching the active mode.
*@

<div class="pf-section pf-section--advanced">

    <header class="pf-section__head">
        <h2 class="pf-section__title">@L[SourceImageSectionDefinition.Definition.TitleKey]</h2>
        <p class="pf-section__subtitle">@L[SourceImageSectionDefinition.Definition.SubtitleKey]</p>
        <a class="pf-section__docs-link" href="@($"docs/{SourceImageSectionDefinition.Definition.Id}")">@L["Section.Docs.Link"]</a>
    </header>

    <section class="pf-section__options">

        <SectionView Section="@SourceImageSectionDefinition.Definition"
                     ViewMode="SectionView.SectionMode.Advanced"
                     ShowHeader="false"
                     OptionIds="@(new[] { "mode" })" />

        @if (ModeSvc.Config.SourceImage.Mode == SourceImageMode.ByIndex)
        {
            <div class="pf-section__group">
                <SectionView Section="@SourceImageSectionDefinition.Definition"
                             ViewMode="SectionView.SectionMode.Advanced"
                             ShowHeader="false"
                             OptionIds="@(new[] { "image-index" })" />
            </div>
        }

        @if (ModeSvc.Config.SourceImage.Mode == SourceImageMode.ByName)
        {
            <div class="pf-section__group">
                <SectionView Section="@SourceImageSectionDefinition.Definition"
                             ViewMode="SectionView.SectionMode.Advanced"
                             ShowHeader="false"
                             OptionIds="@(new[] { "image-name" })" />
            </div>
        }

    </section>
</div>

@code {
    protected override void OnInitialized() => ModeSvc.StateChanged += OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => ModeSvc.StateChanged -= OnStateChanged;
}
