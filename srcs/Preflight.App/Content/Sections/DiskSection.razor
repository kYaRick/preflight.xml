@using Preflight.App.Models
@inject IStringLocalizer<SharedResources> L
@inject ModeService ModeSvc
@implements IDisposable

@*
    Custom Advanced layout for the "Disk & install target" section.

    Schneegans picks one of three PE/partition flavours: Interactive (Windows Setup
    handles the disk), Unattended (we wipe and lay out the target disk) and CustomScript
    (a user diskpart script). The conditional blocks below render only the subset that
    applies to the current mode so the form stays compact. The target-disk index only
    matters for Unattended (it becomes UnattendedPartitionSettings.TargetDisk); a custom
    script selects its own disk via "SELECT DISK=".
*@

<div class="pf-section pf-section--advanced">

    <header class="pf-section__head">
        <h2 class="pf-section__title">@L[DiskSectionDefinition.Definition.TitleKey]</h2>
        <p class="pf-section__subtitle">@L[DiskSectionDefinition.Definition.SubtitleKey]</p>
        <a class="pf-section__docs-link" href="@($"docs/{DiskSectionDefinition.Definition.Id}")">@L["Section.Docs.Link"]</a>
    </header>

    <section class="pf-section__options">

        <SectionView Section="@DiskSectionDefinition.Definition"
                     ViewMode="SectionView.SectionMode.Advanced"
                     ShowHeader="false"
                     OptionIds="@(new[] { "mode" })" />

        @if (ModeSvc.Config.Disk.Mode == DiskMode.AutoWipe)
        {
            <div class="pf-section__group">
                <SectionView Section="@DiskSectionDefinition.Definition"
                             ViewMode="SectionView.SectionMode.Advanced"
                             ShowHeader="false"
                             OptionIds="@(new[] { "partition-style", "esp-size-mb", "recovery" })" />

                @if (ModeSvc.Config.Disk.Recovery == RecoveryMode.OnRecoveryPartition)
                {
                    <SectionView Section="@DiskSectionDefinition.Definition"
                                 ViewMode="SectionView.SectionMode.Advanced"
                                 ShowHeader="false"
                                 OptionIds="@(new[] { "recovery-size-mb" })" />
                }

                <SectionView Section="@DiskSectionDefinition.Definition"
                             ViewMode="SectionView.SectionMode.Advanced"
                             ShowHeader="false"
                             OptionIds="@(new[] { "install-disk-index" })" />
            </div>
        }

        @if (ModeSvc.Config.Disk.Mode == DiskMode.CustomScript)
        {
            <div class="pf-section__group">
                <SectionView Section="@DiskSectionDefinition.Definition"
                             ViewMode="SectionView.SectionMode.Advanced"
                             ShowHeader="false"
                             OptionIds="@(new[] { "custom-script" })" />
            </div>
        }

    </section>
</div>

@code {
    protected override void OnInitialized() => ModeSvc.StateChanged += OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => ModeSvc.StateChanged -= OnStateChanged;
}
